# Supabase (optional — required for auth, favorites, saved setups)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public site URL (used for OG metadata). Optional — Vercel auto-fills VERCEL_URL.
# Set this to your final domain in production, e.g. https://setthetable.com
NEXT_PUBLIC_SITE_URL=
