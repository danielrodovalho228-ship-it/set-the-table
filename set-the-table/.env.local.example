# Supabase (optional — required for auth, favorites, saved setups)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key (NEVER in NEXT_PUBLIC_*, NEVER commit).
# Needed by scripts/generate-heroes.ts and the regenerate server action (writes to Storage).
# Dashboard → Project Settings → API → "service_role" or "Secret keys" section.
SUPABASE_SERVICE_ROLE_KEY=

# AI image generation
# Provider = openai | fal | replicate
IMAGE_PROVIDER=openai
OPENAI_API_KEY=sk-proj-...
# FAL_API_KEY=
# REPLICATE_API_TOKEN=

# Amazon affiliate tag (appended to /dp/ASIN links for your own products)
NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=

# Public site URL (used for OG metadata). Optional — Vercel auto-fills VERCEL_URL.
# Set this to your final domain in production, e.g. https://setthetable.com
NEXT_PUBLIC_SITE_URL=
